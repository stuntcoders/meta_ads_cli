# Optional: override the named-environment store path (especially for tests/automation).
META_CLI_ENVIRONMENTS_FILE=/path/to/private/meta-cli-environments.yaml

# Legacy only: these override matching keys when an explicit --auth-config/--config
# YAML file is supplied. They are not used instead of selecting a named environment.
META_ACCESS_TOKEN=your_meta_access_token
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_AD_ACCOUNT_ID=act_1234567890
META_API_VERSION=v25.0
